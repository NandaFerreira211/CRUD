<Window x:Class="CRUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CRUD"
        mc:Ignorable="d"
        Title="Login de usuário" Height="450" Width="800">
    <Grid>
        <!-- Cartão Central Branco -->
        <Border Background="White" 
                CornerRadius="15" 
                Margin="30" 
                Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#FFE0D0D0" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <!-- Título -->
                <TextBlock Text="Bem-vindo" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="#000000" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"/>

                <!-- Campo Username -->
                <TextBlock Text="Usuário" 
                           FontSize="12" 
                           FontWeight="Bold" 
                           Foreground="#000000" 
                           Margin="0,0,0,5"/>
                <TextBox Name="txtUsuario" 
                         Height="35" 
                         Padding="5" 
                         VerticalContentAlignment="Center"
                         Background="#FFFFF0F5" 
                         BorderBrush="#FFFFC0CB" 
                         BorderThickness="1"/>

                <!-- Campo Senha -->
                <TextBlock Text="Senha" 
                           FontSize="12" 
                           FontWeight="Bold" 
                           Foreground="#000000" 
                           Margin="0,15,0,5"/>
                <PasswordBox Name="txtSenha" 
                             Height="35" 
                             Padding="5" 
                             VerticalContentAlignment="Center"
                             Background="#FFFFF0F5" 
                             BorderBrush="#FFFFC0CB" 
                             BorderThickness="1"
                             Margin="0,0,0,30"/>

                <!-- Botão Entrar -->
                <Button Name="btnEntrar" 
                        Content="Entrar" 
                        Height="40" 
                        Background="#FFFFB6C1" 
                        Foreground="#000000" 
                        FontWeight="Bold" 
                        FontSize="14"
                        BorderThickness="0" 
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Botão Cadastrar -->
                <Button Name="btnCadastrar" 
                        Content="Não tem conta? Cadastre-se" 
                        Background="Transparent" 
                        Foreground="#000000" 
                        BorderThickness="0" 
                        Margin="0,15,0,0" 
                        Cursor="Hand"
                        />
            </StackPanel>
        </Border>
    </Grid>
</Window>
