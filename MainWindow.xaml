<Window x:Class="CRUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock FontSize="16" FontWeight="Bold" Text="Nome:" />
            <TextBox x:Name="TxtNome" FontSize="16" />
            <TextBlock FontSize="16" FontWeight="Bold" Text="Username:" />
            <TextBox x:Name="TxtUsername" FontSize="16" />
            <TextBlock FontSize="16" FontWeight="Bold" Text="Email:" />
            <TextBox x:Name="TxtEmail" FontSize="16" />
            <TextBlock FontSize="16" FontWeight="Bold" Text="Senha:" />
            <PasswordBox x:Name="TxtSenha" FontSize="16" />
            <Button Content="Cadastrar" Click="ButtonBase_OnClick" FontSize="16" />
        </StackPanel>
    </Grid>
</Window>