<Window x:Class="CRUD.MeuPerfil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CRUD"
        mc:Ignorable="d"
        Title="Meu Perfil" 
        Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Grid Background="#F9FAFB">
        <Border Background="White"
                CornerRadius="8"
                Padding="30"
                Width="650"
                Height="460"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- COLUNA ESQUERDA: FOTO DE PERFIL -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Foto de Perfil Circular (Usa uma imagem padrão da web) -->
                    <Ellipse Width="120" Height="120" Stroke="#E5E7EB" StrokeThickness="2">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcToZcO5aepzw7l6xfhqJv41mCbUyNQ6XuyfxAs" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Botão Opcional para Alterar Foto -->
                    <Button x:Name="BtnAlterarFoto"
                            Content="Alterar Foto"
                            Background="Transparent"
                            Foreground="#2563EB"
                            BorderThickness="0"
                            Margin="0,15,0,0"
                            Cursor="Hand"
                           >
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       HorizontalAlignment="Center"
                                                       FontSize="13"
                                                       TextDecorations="Underline" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- COLUNA DIREITA: FORMULÁRIO E AÇÕES -->
                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Título -->
                    <TextBlock Grid.Row="0" 
                               Text="Configurações do Perfil"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"
                               Margin="0,0,0,20" />

                    <!-- Campos de Edição (2x2 Grid) -->
                    <UniformGrid Grid.Row="1" Columns="2" Rows="2" VerticalAlignment="Top">
                        <!-- Nome -->
                        <StackPanel Margin="5,5,10,5">
                            <TextBlock Text="Nome Completo" FontSize="13" Foreground="#374151" Margin="0,0,0,5" />
                            <TextBox x:Name="TxtNome" Height="35" VerticalContentAlignment="Center" Padding="5,0" />
                        </StackPanel>

                        <!-- Usuário -->
                        <StackPanel Margin="10,5,5,5">
                            <TextBlock Text="Usuário" FontSize="13" Foreground="#374151" Margin="0,0,0,5" />
                            <TextBox x:Name="TxtUsuario" Height="35" VerticalContentAlignment="Center" Padding="5,0" />
                        </StackPanel>

                        <!-- Email -->
                        <StackPanel Margin="5,15,10,5">
                            <TextBlock Text="E-mail" FontSize="13" Foreground="#374151" Margin="0,0,0,5" />
                            <TextBox x:Name="TxtEmail" Height="35" VerticalContentAlignment="Center" Padding="5,0" />
                        </StackPanel>

                        <!-- Senha -->
                        <StackPanel Margin="10,15,5,5">
                            <TextBlock Text="Nova Senha" FontSize="13" Foreground="#374151" Margin="0,0,0,5" />
                            <PasswordBox x:Name="TxtSenha" Height="35" VerticalContentAlignment="Center" Padding="5,0" />
                        </StackPanel>
                    </UniformGrid>

                    <!-- Botões de Ação -->
                    <Grid Grid.Row="3" Margin="5,20,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Botão Deletar -->
                        <Button x:Name="BtnDeletarPerfil"
                                Grid.Column="0"
                                Content="Excluir Conta"
                                Height="40"
                                Width="120"
                                Background="#EF4444"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnDeletarPerfil_OnClick"
                                >
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5" />
                                </Style>
                            </Button.Resources>
                        </Button>

                        <!-- Botão Salvar -->
                        <Button x:Name="BtnSalvar"
                                Grid.Column="2"
                                Content="Salvar Alterações"
                                Height="40"
                                Width="160"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnSalvar_OnClick"
                               >
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
