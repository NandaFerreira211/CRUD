<Window x:Class="CRUD.Feed"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Feed" Height="680" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White"
                CornerRadius="8"
                Padding="30"
                Width="420"
                Height="600">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Feed Social"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#111827"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Margin="0,0,0,20"
                                Padding="0,0,0,15">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <TextBlock Text="Cabritinha Falante"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="#111827" />
                                        <TextBlock Text="@cabritinhabeeh"
                                                   Foreground="#374151"
                                                   FontSize="13"
                                                   Margin="5,0,0,0"
                                                   Opacity="0.7" />
                                    </StackPanel>
                                    <TextBlock Text="08 Jun - 14:30"
                                               Foreground="#374151"
                                               FontSize="12"
                                               Opacity="0.5"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <TextBlock
                                    Text="Beeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeh 🐐"
                                    TextWrapping="Wrap"
                                    FontSize="14"
                                    Foreground="#374151"
                                    Margin="0,0,0,15" />

                                <Button Content="❤️ Curtir"
                                        Height="35"
                                        Width="100"
                                        HorizontalAlignment="Left"
                                        Background="#2563EB"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="5" />
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>